<!-- ===== EXPERIENCE SECTION ===== -->
<section id="experience">
    <div class="container">
        <div class="section-header animate-on-scroll">
            <span class="section-label">// 02. experience</span>
            <h2 class="section-title">Work <span>Experience</span></h2>
            <div class="section-line"></div>
        </div>
        <div class="timeline">
            @foreach (var exp in experiences)
            {
                <div class="timeline-item animate-on-scroll">
                    <div class="timeline-header">
                        <div>
                            <div class="timeline-role">@exp.Role</div>
                            <div class="timeline-company">@exp.Company</div>
                        </div>
                        <span class="timeline-period">@exp.Period</span>
                    </div>
                    <ul class="timeline-desc">
                        @foreach (var item in exp.Highlights)
                        {
                            <li>@item</li>
                        }
                    </ul>
                    <div class="timeline-tags">
                        @foreach (var tech in exp.Technologies)
                        {
                            <span class="tag">@tech</span>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ===== PROJECTS SECTION ===== -->
<section id="projects">
    <div class="container">
        <div class="section-header animate-on-scroll">
            <span class="section-label">// 03. projects</span>
            <h2 class="section-title">Featured <span>Projects</span></h2>
            <div class="section-line"></div>
        </div>
        <div class="projects-grid">
            @foreach (var project in projects)
            {
                <div class="project-card animate-on-scroll">
                    <div class="project-header">
                        <div class="project-icon">
                            <i class="@project.Icon"></i>
                        </div>
                        <div class="project-links">
                            @if (!string.IsNullOrEmpty(project.RepoUrl))
                            {
                                <a href="@project.RepoUrl" target="_blank" class="project-link" title="Repository">
                                    <i class="fab fa-github"></i>
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(project.LiveUrl))
                            {
                                <a href="@project.LiveUrl" target="_blank" class="project-link" title="Live Demo">
                                    <i class="fas fa-external-link-alt"></i>
                                </a>
                            }
                        </div>
                    </div>
                    <h3 class="project-title">@project.Title</h3>
                    <p class="project-desc">@project.Description</p>
                    <div class="project-tech">
                        @foreach (var tech in project.Technologies)
                        {
                            <span>@tech</span>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ===== SKILLS SECTION ===== -->
<section id="skills">
    <div class="container">
        <div class="section-header animate-on-scroll">
            <span class="section-label">// 04. skills</span>
            <h2 class="section-title">Technical <span>Skills</span></h2>
            <div class="section-line"></div>
        </div>
        <div class="skills-container">
            @foreach (var category in skillCategories)
            {
                <div class="skill-category animate-on-scroll">
                    <div class="skill-category-title">
                        <i class="@category.Icon"></i>&nbsp;@category.Name
                    </div>
                    <div class="skill-list">
                        @foreach (var skill in category.Skills)
                        {
                            <div class="skill-item">
                                <div class="skill-info">
                                    <span class="skill-name">@skill.Name</span>
                                    <span class="skill-level">@(skill.Level)%</span>
                                </div>
                                <div class="skill-bar">
                                    <div class="skill-fill" style="--skill-width: @(skill.Level)%"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="skills-tags-section animate-on-scroll">
            <p class="skills-tags-title">// All Technologies</p>
            <div class="skills-tags">
                <span class="skill-tag"><i class="devicon-csharp-plain"></i>&nbsp;C#</span>
                <span class="skill-tag"><i class="devicon-dotnetcore-plain"></i>&nbsp;.NET Core</span>
                <span class="skill-tag"><i class="devicon-java-plain"></i>&nbsp;Java</span>
