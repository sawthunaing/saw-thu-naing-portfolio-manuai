                <div class="contact-details">
                    <div class="contact-item">
                        <div class="contact-item-icon"><i class="fas fa-envelope"></i></div>
                        <a href="mailto:sawthunaing@gmail.com">sawthunaing&#64;gmail.com</a>
                    </div>
                    <div class="contact-item">
                        <div class="contact-item-icon"><i class="fas fa-phone"></i></div>
                        <span>+44 7405 473363</span>
                    </div>
                    <div class="contact-item">
                        <div class="contact-item-icon"><i class="fas fa-map-marker-alt"></i></div>
                        <span>United Kingdom</span>
                    </div>
                    <div class="contact-item">
                        <div class="contact-item-icon"><i class="fab fa-linkedin"></i></div>
                        <a href="https://linkedin.com/in/sawthunaing" target="_blank">linkedin.com/in/sawthunaing</a>
                    </div>
                </div>

                <div class="social-links">
                    <a href="https://github.com/sawthunaing" target="_blank" class="social-link" title="GitHub">
                        <i class="fab fa-github"></i>
                    </a>
                    <a href="https://linkedin.com/in/sawthunaing" target="_blank" class="social-link" title="LinkedIn">
                        <i class="fab fa-linkedin-in"></i>
                    </a>
                    <a href="mailto:sawthunaing@gmail.com" class="social-link" title="Email">
                        <i class="fas fa-envelope"></i>
                    </a>
                    <a href="/resume.pdf" download class="social-link" title="Download Resume">
                        <i class="fas fa-file-pdf"></i>
                    </a>
                </div>
            </div>

            <div class="contact-form animate-on-scroll">
                @if (formSubmitted)
                {
                    <div class="form-success">
                        <i class="fas fa-check-circle"></i>&nbsp;
                        Thank you! Your message has been sent. I'll get back to you soon.
                    </div>
                }
                else
                {
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Name</label>
                            <input type="text" class="form-control" placeholder="John Doe" @bind="contactName" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" placeholder="john@example.com" @bind="contactEmail" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Subject</label>
                        <input type="text" class="form-control" placeholder="Project Inquiry / Collaboration" @bind="contactSubject" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Message</label>
                        <textarea class="form-control" rows="5" placeholder="Tell me about your project or opportunity..." @bind="contactMessage"></textarea>
                    </div>
                    <button class="btn-submit" @onclick="SubmitForm">
                        <i class="fas fa-paper-plane"></i>&nbsp;Send Message
                    </button>
                }
            </div>
        </div>
    </div>
</section>

@code {
    private bool formSubmitted = false;
    private string contactName = "";
    private string contactEmail = "";
    private string contactSubject = "";
    private string contactMessage = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var typingTexts = new[] {
                "Senior .NET Developer",
                "FinTech Engineer",
                "Cloud Architect",
                "Microservices Expert",
                "API Gateway Specialist"
            };
            await JS.InvokeVoidAsync("initTypingEffect", "typing-text", typingTexts, 80);
            await JS.InvokeVoidAsync("initScrollAnimations");
            await AnimateSkillBarsAsync();
        }
    }

    private async Task AnimateSkillBarsAsync()
    {
        await Task.Delay(800);
        await JS.InvokeVoidAsync("eval", "document.querySelectorAll('.skill-fill').forEach(el => el.classList.add('animated'));");
    }

    private async Task ScrollTo(string id)
    {
        await JS.InvokeVoidAsync("scrollToSection", id);
    }

    private async Task SubmitForm()
    {
        if (!string.IsNullOrWhiteSpace(contactName) && !string.IsNullOrWhiteSpace(contactEmail))
        {
            formSubmitted = true;
        }
        await Task.CompletedTask;
    }

