                <span class="skill-tag"><i class="devicon-javascript-plain"></i>&nbsp;JavaScript</span>
                <span class="skill-tag"><i class="devicon-html5-plain"></i>&nbsp;HTML5</span>
                <span class="skill-tag"><i class="devicon-css3-plain"></i>&nbsp;CSS3</span>
                <span class="skill-tag"><i class="devicon-mysql-plain"></i>&nbsp;MySQL</span>
                <span class="skill-tag"><i class="devicon-microsoftsqlserver-plain"></i>&nbsp;MSSQL</span>
                <span class="skill-tag"><i class="devicon-postgresql-plain"></i>&nbsp;PostgreSQL</span>
                <span class="skill-tag"><i class="devicon-mongodb-plain"></i>&nbsp;MongoDB</span>
                <span class="skill-tag"><i class="devicon-redis-plain"></i>&nbsp;Redis</span>
                <span class="skill-tag"><i class="devicon-amazonwebservices-plain-wordmark"></i>&nbsp;AWS</span>
                <span class="skill-tag"><i class="devicon-azure-plain"></i>&nbsp;Azure</span>
                <span class="skill-tag"><i class="fab fa-google"></i>&nbsp;GCP</span>
                <span class="skill-tag"><i class="devicon-docker-plain"></i>&nbsp;Docker</span>
                <span class="skill-tag"><i class="devicon-kubernetes-plain"></i>&nbsp;Kubernetes</span>
                <span class="skill-tag"><i class="devicon-nginx-plain"></i>&nbsp;Nginx</span>
                <span class="skill-tag"><i class="devicon-git-plain"></i>&nbsp;Git</span>
                <span class="skill-tag"><i class="devicon-jira-plain"></i>&nbsp;Jira</span>
            </div>
        </div>
    </div>
</section>

<!-- ===== BLOG SECTION ===== -->
<section id="blog">
    <div class="container">
        <div class="section-header animate-on-scroll">
            <span class="section-label">// 05. writing</span>
            <h2 class="section-title">Technical <span>Articles</span></h2>
            <div class="section-line"></div>
        </div>
        <div class="blog-grid">
            @foreach (var post in blogPosts)
            {
                <div class="blog-card animate-on-scroll">
                    <div class="blog-card-header">
                        <span class="blog-category">@post.Category</span>
                        <span class="blog-date">@post.Date</span>
                    </div>
                    <div class="blog-card-body">
                        <h3 class="blog-title">@post.Title</h3>
                        <p class="blog-excerpt">@post.Excerpt</p>
                        <div class="blog-footer">
                            <span class="blog-read-time"><i class="fas fa-clock"></i>&nbsp;@post.ReadTime</span>
                            <a href="@post.Url" target="_blank" class="blog-read-more">
                                Read More&nbsp;<i class="fas fa-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ===== CONTACT SECTION ===== -->
<section id="contact">
