@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="page-wrapper">
    <nav class="navbar @(isScrolled ? "scrolled" : "")">
        <div class="nav-container">
            <div class="nav-logo" @onclick='() => ScrollTo("hero")'>&lt;<span>STN</span> /&gt;</div>
            <ul class="nav-links">
                <li><a href="#about" @onclick='() => ScrollTo("about")' @onclick:preventDefault>About</a></li>
                <li><a href="#experience" @onclick='() => ScrollTo("experience")' @onclick:preventDefault>Experience</a></li>
                <li><a href="#projects" @onclick='() => ScrollTo("projects")' @onclick:preventDefault>Projects</a></li>
                <li><a href="#skills" @onclick='() => ScrollTo("skills")' @onclick:preventDefault>Skills</a></li>
                <li><a href="#blog" @onclick='() => ScrollTo("blog")' @onclick:preventDefault>Blog</a></li>
                <li><a href="#contact" @onclick='() => ScrollTo("contact")' @onclick:preventDefault>Contact</a></li>
            </ul>
            <a href="https://github.com/sawthunaing" target="_blank" class="nav-cta">
                <i class="fab fa-github"></i>&nbsp;GitHub
            </a>
            <button class="nav-mobile-toggle" @onclick="ToggleMobileMenu">
                <i class="fas @(mobileMenuOpen ? "fa-times" : "fa-bars")"></i>
            </button>
        </div>
    </nav>

    <div class="mobile-menu @(mobileMenuOpen ? "open" : "")">
        <ul>
            <li><a href="#about" @onclick="@(() => CloseMobileAndScroll("about"))" @onclick:preventDefault>About</a></li>
            <li><a href="#experience" @onclick="@(() => CloseMobileAndScroll("experience"))" @onclick:preventDefault>Experience</a></li>
            <li><a href="#projects" @onclick="@(() => CloseMobileAndScroll("projects"))" @onclick:preventDefault>Projects</a></li>
            <li><a href="#skills" @onclick="@(() => CloseMobileAndScroll("skills"))" @onclick:preventDefault>Skills</a></li>
            <li><a href="#blog" @onclick="@(() => CloseMobileAndScroll("blog"))" @onclick:preventDefault>Blog</a></li>
            <li><a href="#contact" @onclick="@(() => CloseMobileAndScroll("contact"))" @onclick:preventDefault>Contact</a></li>
        </ul>
    </div>

    <main>
        @Body
    </main>

    <footer class="footer">
        <div class="footer-inner">
            <p class="footer-copy">
                &copy; 2025 <span>Saw Thu Naing</span>. Built with Blazor WebAssembly.
            </p>
            <div class="footer-links">
                <a href="https://github.com/sawthunaing" target="_blank">GitHub</a>
                <a href="https://linkedin.com/in/sawthunaing" target="_blank">LinkedIn</a>
                <a href="#contact" @onclick='() => ScrollTo("contact")' @onclick:preventDefault>Contact</a>
            </div>
        </div>
    </footer>
</div>

@code {
    private bool isScrolled = false;
    private bool mobileMenuOpen = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initScrollAnimations");
        }
    }

    private async Task ScrollTo(string id)
    {
        await JS.InvokeVoidAsync("scrollToSection", id);
    }

    private void ToggleMobileMenu()
    {
        mobileMenuOpen = !mobileMenuOpen;
    }

    private async Task CloseMobileAndScroll(string id)
    {
        mobileMenuOpen = false;
        await ScrollTo(id);
    }
}
